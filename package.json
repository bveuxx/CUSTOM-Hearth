	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"dashboard",
		"home",
		"launcher"
	],
	"author": "ondreu",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	}
}
