{
	"name": "hearth",
	"version": "0.9.0",
	"description": "A beautiful, customizable home screen for Obsidian — search, dashboard, and launcher in one.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck"
